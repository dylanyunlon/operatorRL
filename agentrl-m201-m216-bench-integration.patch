         }
 
     def to_json(self) -> str:
@@ -300,21 +311,34 @@ class FlightRecorderEmitter:
         return {
             "emitted_count": self._emitted_count,
             "last_position": self._last_position,
+            "bench_span_count": 0,  # M215: bench span tracking
         }
 
 
 def create_emitter(
-    flight_recorder: Any,
+    flight_recorder: Any = None,
+    *,
+    agent_id: str | None = None,
     **kwargs: Any,
 ) -> FlightRecorderEmitter:
     """
     Factory function to create a FlightRecorderEmitter.
 
     Args:
-        flight_recorder: Agent OS FlightRecorder
+        flight_recorder: Agent OS FlightRecorder (optional if agent_id given)
+        agent_id: Agent identifier for bench-mode emitter creation
         **kwargs: Additional configuration
 
     Returns:
         Configured FlightRecorderEmitter
     """
+    if flight_recorder is None:
+        # Create a minimal flight recorder stub for bench-only mode
